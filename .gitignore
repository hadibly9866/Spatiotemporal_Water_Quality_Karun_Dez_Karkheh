# Byte-compiled / optimized / DLL files
*__pycache__/
*.py[cod]
*.class

# C extensions
*.so

# Distribution / packaging
*.egg-info/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-link
*.egg
file:Subprocess*

# PyInstaller
# it is not safe to ignore *.so files. We can, however, ignore.
# pyinstaller information.
# This is an umbrella pattern to ignore pyinstaller generated files.
*_MEI*

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage/
.cache/
nosetests.xml
htmlcov/
pytest.xml
junit.xml
.pytest_cache/

# Environments
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE / Editor specific files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
*.bak
*.swp

# Large data files (if any are generated and should be ignored)
data/*.csv
data/*.xlsx
outputs/*.csv
outputs/*.xlsx
outputs/*.png
outputs/*.jpg
outputs/*.pdf
